# ===== Notion =====
# 到 https://www.notion.so/my-integrations 建立 Integration 後取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database 頁面 URL 中的 32 碼 ID（去掉連字號）
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== LINE Bot =====
# LINE Developers Console > Messaging API > Channel access token
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 要接收推播的對象 ID（個人用 U 開頭，群組用 C 開頭）
# 可透過 LINE Bot webhook 收到的事件取得自己的 userId
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 地理編碼（選填） =====
# 留空則改用免費的 Nominatim（OpenStreetMap），有此 key 則優先使用 Google
GOOGLE_GEOCODING_API_KEY=

# ===== 資料庫 =====
DB_PATH=data/rental_detective.db

# ===== 執行模式 =====
# ci（預設）：GitHub Actions headless 模式
# local：本機執行，減少反爬蟲偵測
RUN_MODE=ci
